rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint for User Entity
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) && 
             data.keys().size() >= 3 && data.keys().size() <= 10 &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100);
    }

    match /users/{userId} {
      // Path Hardening
      allow get: if isOwner(userId) && isValidId(userId);
      
      // Strict Creation
      allow create: if isOwner(userId) && 
                    isValidId(userId) && 
                    isValidUser(incoming()) && 
                    incoming().createdAt == request.time;
                    
      // Action-Based Update (Tiered Identity)
      allow update: if isOwner(userId) && 
                    isValidId(userId) && 
                    isValidUser(incoming()) && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().uid == existing().uid &&
                    incoming().email == existing().email &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'lastLogin']);
                    
      allow delete: if false; // Users cannot delete their profiles for audit trails
    }
  }
}
